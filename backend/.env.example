APP_NAME=Optimus API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
AUTO_CREATE_TABLES=false
DATABASE_URL=postgresql+psycopg://optimus:optimus@localhost:5432/optimus
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
AUTH_REQUIRED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_MIN_LENGTH=12
JWT_SECRET_KEY=change-this-jwt-secret-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=60
MAX_UPLOAD_SIZE_BYTES=5000000
RATE_LIMIT_MAX_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60
BLOCK_PROMPT_INJECTION=false
AUDIT_LOG_PATH=logs/audit.jsonl
# On Vercel serverless, prefer /tmp for writable runtime storage.
# AUDIT_LOG_PATH=/tmp/audit.jsonl
AUDIT_EXPORT_MAX_LINES=5000
