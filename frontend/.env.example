# Backend API URL (required)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Session secret for frontend login protection (required)
# Generate a secure random string: openssl rand -base64 48
# Minimum 32 characters recommended
APP_LOGIN_SESSION_SECRET=change-this-to-a-secure-random-string-min-32-chars

# Session max age in seconds (optional, defaults to 3600 = 1 hour)
APP_LOGIN_SESSION_MAX_AGE_SECONDS=3600

# Supabase configuration (optional, for notes feature)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
